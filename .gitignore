# ──────────────────────────────────────────────────────────────
# Python environments & caches  /  파이썬 가상환경 및 캐시
# ──────────────────────────────────────────────────────────────
.venv-dlc-gpu/
.venv-keypoint/
.venv/
venv/
env/
.uv-cache/
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ──────────────────────────────────────────────────────────────
# Node / Vite UI  /  노드 · Vite UI
# ──────────────────────────────────────────────────────────────
node_modules/
ui/dist/
ui/.vite/
*.log
.env
.env.*
!.env.example

# ──────────────────────────────────────────────────────────────
# Model weights (track via Git LFS or distribute separately)
# 모델 가중치 (Git LFS 사용 또는 별도 배포 권장)
# ──────────────────────────────────────────────────────────────
*.pt
*.pth
*.onnx
*.h5
*.joblib
*.pkl

# ──────────────────────────────────────────────────────────────
# Datasets — large raw video  /  대용량 원본 영상 데이터셋
# ──────────────────────────────────────────────────────────────
*.mp4
*.mov
*.avi
*.webm

# ──────────────────────────────────────────────────────────────
# Generated / heavy report artifacts  /  생성된 무거운 산출물
# (keep the human-written *.md / *.csv summaries, drop the caches)
# (사람이 작성한 *.md / *.csv 요약은 유지, 캐시는 제외)
# ──────────────────────────────────────────────────────────────
**/cache/
*.npz
reports/**/*.png
reports/**/*.jpg
*.pptx
PET_RPPG_Deploy.zip
# Generated pose-classifier demo outputs (regenerate with tools/pose_classifier.py)
# 자세 분류기 생성 산출물 (재생성 가능)
reports/pose_*/
# Note: presentation_images/ is intentionally tracked (referenced as docs).
# 참고: presentation_images/ 는 문서 자산으로 의도적으로 추적합니다.
# Local R&D proposal-deck workspace (build_deck.js says "not for git")
proposal/

# ──────────────────────────────────────────────────────────────
# OS / editor cruft  /  OS · 에디터 잔여 파일
# ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
